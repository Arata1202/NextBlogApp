{
  "name": "nextblogapp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.8.0",
  "pnpm": {
    "overrides": {
      "eslint-plugin-jsx-a11y>minimatch": "3.1.5",
      "flat-cache>flatted": "3.4.2",
      "postcss": "8.5.15"
    }
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "build:e2e": "node scripts/e2e/build.mjs",
    "start": "pnpm dlx serve@latest out",
    "lint": "eslint src e2e scripts playwright.config.ts vitest.config.mts",
    "lint:fix": "eslint src e2e scripts playwright.config.ts vitest.config.mts --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "prepare": "husky install",
    "format": "prettier --write --ignore-path .gitignore './**/*.{js,jsx,ts,tsx,mts,json,css,mjs}'"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,mts}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "@next/third-parties": "^16.2.9",
    "@sentry/nextjs": "^10",
    "cheerio": "^1.2.0",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "feed": "^5.2.1",
    "highlight.js": "^11.11.1",
    "microcms-js-sdk": "^3.4.0",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-google-recaptcha": "^3.1.0",
    "react-hook-form": "^7.79.0",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-share": "^5.3.0",
    "react-slick": "^0.31.0",
    "remark-gfm": "^4.0.1",
    "slick-carousel": "^1.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.9",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-google-recaptcha": "^2.1.9",
    "@types/react-slick": "^0.23.13",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.9.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
