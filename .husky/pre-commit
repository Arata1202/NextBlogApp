node_modules/.bin/lint-staged

STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR | tr '\n' ' ')"

if [ -n "$STAGED_FILES" ]; then
  node_modules/.bin/vitest related --run --passWithNoTests $STAGED_FILES
fi

if [ -z "$GOCACHE" ]; then
  export GOCACHE="$(pwd)/tmp/go-build-cache"
  mkdir -p "$GOCACHE"
fi

go test ./...

gitleaks protect --staged
